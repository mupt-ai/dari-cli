name: {{.ProjectName}}
harness: pi

instructions:
  system: prompts/system.md

sandbox:
  provider: e2b
  runtimes:
    node: "20"
  env:
    APP_ENV: example

llm:
  model: openai/gpt-5.5

built_in_tools:
  - read
  - bash
  - edit
  - write

custom_tools:
  - name: repo_search
    path: tools/repo_search
    kind: main
    runtime: typescript
    handler: handler.ts:main
    retries: 2
    timeout_seconds: 20

skills:
  - name: {{.SkillName}}
    path: skills/{{.SkillName}}
