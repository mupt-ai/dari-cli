name: {{.ProjectName}}
harness: pi

instructions:
  system: prompts/system.md

sandbox:
  provider: e2b
  runtimes:
    node: "20"
  env:
    APP_ENV: example

llm:
  model: openai/gpt-5.5

built_in_tools:
  - read
  - bash
  - edit
  - write

skills:
  - name: {{.SkillName}}
    path: skills/{{.SkillName}}
