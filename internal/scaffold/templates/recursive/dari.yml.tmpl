name: {{.ProjectName}}
harness: pi

instructions:
  system: prompts/system.md

sandbox:
  provider: e2b
  runtimes:
    node: "20"
    python: "3.13"
  packages:
    apt:
      - ca-certificates
      - curl
      - tar
  setup:
    script: scripts/install-dari.sh
  env:
    DARI_API_URL: {{ yamlQuote .APIURL }}
    DARI_SOURCE_BUNDLE_ROOT: /workspace/.dari/agent-resources/source-bundle
  secrets:
    - DARI_API_KEY

llm:
  model: openai/gpt-5.5

built_in_tools:
  - read
  - bash
  - edit
  - write

skills:
  - name: dari
    path: skills/dari
  - name: {{.SkillName}}
    path: skills/{{.SkillName}}
